-- Aziz Hub V3: Official GitHub Loader Protocol
local SECRET_KEY = "test105" -- Change this to your desired password!
local RAW_GITHUB_URL = "https://raw.githubusercontent.com/chitdm/Rival-script/refs/heads/main/Aziz%20hun"

local ScreenGui = Instance.new("ScreenGui")
local Frame = Instance.new("Frame")
local UICorner = Instance.new("UICorner")
local TitleLabel = Instance.new("TextLabel")
local KeyInput = Instance.new("TextBox")
local VerifyBtn = Instance.new("TextButton")
local Corner1 = Instance.new("UICorner")
local Corner2 = Instance.new("UICorner")

local success, targetParent = pcall(function() return game:GetService("CoreGui") end)
if not success or not targetParent then
    targetParent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
end
ScreenGui.Parent = targetParent

Frame.Name = "KeySystemFrame"
Frame.Parent = ScreenGui
Frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
Frame.Position = UDim2.new(0.4, 0, 0.4, 0)
Frame.Size = UDim2.new(0, 320, 0, 150)
Frame.Active = true
Frame.Draggable = true
UICorner.Parent = Frame

TitleLabel.Name = "TitleLabel"
TitleLabel.Parent = Frame
TitleLabel.BackgroundTransparency = 1
TitleLabel.Size = UDim2.new(1, 0, 0, 40)
TitleLabel.Font = Enum.Font.SourceSansBold
TitleLabel.Text = "Aziz Hub V3 — Enter Key"
TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
TitleLabel.TextSize = 16

KeyInput.Name = "KeyInput"
KeyInput.Parent = Frame
KeyInput.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
KeyInput.Position = UDim2.new(0, 20, 0, 50)
KeyInput.Size = UDim2.new(0, 280, 0, 40)
KeyInput.Font = Enum.Font.SourceSans
KeyInput.PlaceholderText = "Type password here..."
KeyInput.Text = ""
KeyInput.TextColor3 = Color3.fromRGB(255, 255, 255)
KeyInput.TextSize = 15
Corner1.Parent = KeyInput

VerifyBtn.Name = "VerifyBtn"
VerifyBtn.Parent = Frame
VerifyBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
VerifyBtn.Position = UDim2.new(0, 20, 0, 100)
VerifyBtn.Size = UDim2.new(0, 280, 0, 35)
VerifyBtn.Font = Enum.Font.SourceSansBold
VerifyBtn.Text = "Verify Key"
VerifyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
VerifyBtn.TextSize = 15
Corner2.Parent = VerifyBtn

VerifyBtn.MouseButton1Click:Connect(function()
    if KeyInput.Text == SECRET_KEY then
        TitleLabel.Text = "Key Approved! Fetching menu..."
        TitleLabel.TextColor3 = Color3.fromRGB(50, 255, 100)
        task.wait(0.5)
        
        -- Activate internal validation flag required by your GitHub file
        _G.AzizHubAuthenticated = true
        
        local httpSuccess, scriptCode = pcall(function()
            return game:HttpGet(RAW_GITHUB_URL)
        end)
        
        if httpSuccess and scriptCode then
            ScreenGui:Destroy()
            loadstring(scriptCode)()
        else
            TitleLabel.Text = "Connection Error. Try again."
            TitleLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
            _G.AzizHubAuthenticated = nil
        end
    else
        TitleLabel.Text = "Incorrect Key! Try again."
        TitleLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
        KeyInput.Text = ""
    end
end)
